# Copy this file to `.env` and fill in your keys (do not commit `.env`).
# Keys from https://build.nvidia.com — use separate keys per feature if NVIDIA issued them that way,
# or set NVIDIA_API_KEY alone to use one key for all three.

# Speech-to-text (Tamil) — OpenAI-compatible /audio/transcriptions
NVIDIA_API_KEY_STT=

# Tamil → English translation — /v1/chat/completions
NVIDIA_API_KEY_TRANSLATION=

# Text-to-speech for slang output — /v1/audio/speech
NVIDIA_API_KEY_TTS=

# Optional: single key for STT + translation + TTS if you only have one
# NVIDIA_API_KEY=

# Optional overrides (defaults work for spoken Tamil + Magpie TTS)
# NVIDIA_ASR_MODEL=openai/whisper-large-v3
# NVIDIA_ASR_LANGUAGE=ta
# NVIDIA_TRANSLATION_MODEL=meta/llama-3.1-8b-instruct
# NVIDIA_TTS_MODEL=nvidia/magpie-tts-multilingual
# NVIDIA_TTS_VOICE=Magpie-Multilingual.HI-IN.Aria
